{
  "stryker-config": {
    "project-info": {
      "module": "PosSharp.Core"
    },
    "project": "src/PosSharp.Core/PosSharp.Core.csproj",
    "mutate": [
      "**/*.cs",
      "!obj/**"
    ],
    "test-projects": [
      "test/PosSharp.Core.Tests/PosSharp.Core.Tests.csproj"
    ],
    "reporters": [
      "html",
      "progress",
      "cleartext",
      "json"
    ],
    "thresholds": {
      "break": 85,
      "low": 90,
      "high": 95
    },
    "concurrency": 4,
    "test-runner": "mtp",
    "coverage-analysis": "all"
  }
}
